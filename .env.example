PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
# Optional but recommended for server-side social image lookups.
GOOGLE_MAPS_SERVER_API_KEY=YOUR_SERVER_SIDE_GOOGLE_MAPS_API_KEY
# Optional: existing link slug used for navqr.app social preview image.
SITE_PREVIEW_SLUG=YOUR_FEATURED_LINK_SLUG
# Required for server-side redirect lookups when links table RLS is enabled.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
# Optional: override the default monthly prices used for Checkout (amounts in cents).
STRIPE_PRO_MONTHLY_AMOUNT=1200
STRIPE_TEAM_MONTHLY_AMOUNT=3900
